# Copy to ".env" and fill in. Used with: docker run --env-file .env ...

# --- OneDrive credentials ---
CLIENT_ID=00000000-0000-0000-0000-000000000000
TENANT_ID=organizations
REFRESH_TOKEN=

# Own OneDrive only, no admin consent
SCOPES=offline_access Files.Read User.Read

# --- Dashboard settings ---
ONEDRIVE_FOLDER=Sysinfra_Workload
CACHE_TTL_SECONDS=300

# Normal working hours per day (used for the capacity reference line).
STANDARD_DAY_HOURS=8
# Holidays to exclude from capacity. Either list them here (comma/space separated
# ISO dates) and/or edit holidays.txt.
# HOLIDAYS=2025-01-01,2025-04-14,2025-04-15
# HOLIDAYS_FILE=holidays.txt

# --- Local testing instead of OneDrive (optional) ---
# Reads *.csv from this folder and ignores OneDrive entirely.
# LOCAL_DATA_DIR=/data

# --- Or use a mounted token.json instead of the 3 vars above ---
# TOKEN_FILE=/secrets/token.json
